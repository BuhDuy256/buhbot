' =============================================================================
' solution-flow.puml
'
' Reverse-engineered from the CURRENT src/ implementation (not from the design
' docs — where behavior differs from docs/lifecycle/*.md, the code below is
' what actually runs). Four independent diagrams in this file:
'
'   1. Module Map            — src/ component/dependency overview
'   2. Daily Sync Pipeline    — main.py entry point, overall run lifecycle
'   3. Article FSM            — process.py, per-article state machine
'   4. Chunk FSM               — uploader.py, per-chunk state machine
'   5. Eval Runner Flow        — evals/run_eval.py, an independent flow that
'                                 queries the deployed Assistant and is NOT
'                                 part of the daily sync pipeline
' =============================================================================


' =============================================================================
' 1. MODULE MAP — src/ dependency overview
' =============================================================================
@startuml module_map
title Module Map — src/ (dependency overview)
skinparam componentStyle rectangle

package "Entry Point" {
  [main.py]
}

package "Phases (orchestration)" {
  [process.py]
  [reconcile.py]
  [report.py]
}

package "Adapters (I/O)" {
  [zendesk.py]
  [vector_store.py]
  [uploader.py]
  [artifacts.py]
}

package "Pure Transforms" {
  [content.py]
  [chunk.py]
}

package "State & Config" {
  [state.py]
  [config.py]
  [settings.py]
  [lock.py]
}

[main.py] --> [lock.py]
[main.py] --> [settings.py]
[main.py] --> [state.py]
[main.py] --> [vector_store.py]
[main.py] --> [reconcile.py]
[main.py] --> [zendesk.py]
[main.py] --> [process.py]
[main.py] --> [report.py]

[process.py] --> [content.py]
[process.py] --> [chunk.py]
[process.py] --> [uploader.py]
[process.py] --> [vector_store.py]
[process.py] --> [state.py]
[process.py] --> [artifacts.py]
[process.py] --> [report.py]
[process.py] --> [zendesk.py] : Article type only

[reconcile.py] --> [vector_store.py]
[uploader.py] --> [chunk.py] : ChunkText type only
[uploader.py] --> [config.py]
[zendesk.py] --> [artifacts.py]
[zendesk.py] --> [config.py]
[vector_store.py] --> [config.py]
[chunk.py] --> [config.py]
[state.py] --> [config.py]
[lock.py] --> [config.py]
[artifacts.py] --> [config.py]

note bottom of [config.py]
  Only OPENAI_API_KEY is read from the
  environment (settings.py). Everything
  else here (ENV, STORE_NAME, chunk
  budgets, paths) is a hard-coded constant.
end note
@enduml


' =============================================================================
' 2. DAILY SYNC PIPELINE — main.py (entry point + overall lifecycle)
' =============================================================================
@startuml daily_sync_pipeline
title Daily Sync Pipeline — main.py (Entry Point & Overall Request Lifecycle)

start
:main() invoked;

:single_run_lock() attempts an OS-level advisory lock\non data/.run.lock (flock on POSIX / msvcrt.locking\non Windows);
if (lock acquired?) then (yes)
  :run();
  :settings = load_settings()\n(read OPENAI_API_KEY; raise RuntimeError if missing);
  :client = settings.client() — OpenAI SDK client;
  :state = HashStore.load()\n(read data/hash_store.json, or empty if absent);
  :store_id = vector_store.find_or_create(client, STORE_NAME);
  note right
    client.vector_stores.list() (auto-paginated)
    match by name "optibot-kb":
      found    -> reuse existing store.id
      no match -> client.vector_stores.create(name=...)
  end note
  :reconcile.orphans(client, store_id, state);
  note right
    Crash-orphan sweep before any new work.
    See "Chunk FSM" diagram's upstream data —
    known_good_file_ids() = union of
    chunk_file_ids across ALL CONFIRMED + FAILED
    entries. Any store file NOT in that set is
    deleted as an orphan.
  end note
  :articles = zendesk.fetch_all_articles();
  note right
    GET /api/v2/help_center/en-us/articles (no auth)
    ENV == "development": one capped request
      (per_page=MAX_ARTICLES_DEV=30)
    ENV == "production": follow next_page
      to exhaustion (per_page=100)
    Each raw article is passed through
    artifacts.dump_raw() (no-op unless
    DUMP_ARTIFACTS is on)
  end note
  :report = RunReport();
  :total = len(articles);

  repeat :for (i, art) in enumerate(articles, start=1);
    :print "[process] i/total article {art.id} — {title[:60]}";
    :call process.article(art, client, store_id, state);
    if (did that call raise an exception?) then (yes)
      :print "    -> ERROR: article {art.id} crashed: {exc}";
      :report.add(Outcome.failed(art.id));
      note right
        Per-article try/except: one bad article
        must not take down the other 29-49.
      end note
    else (no)
      :outcome = process.article(...)\n(see "Article FSM" diagram);
      :report.add(outcome);
    endif
  repeat while (more articles remaining?) is (yes) not (no)

  :report.log();
  note right
    print "[report] added=.. updated=.. skipped=.. failed=.. total=.."
    if failed > 0: print the list of failed article ids
  end note
  :code = report.exit_code();
  note right: 1 if any article FAILED, else 0
else (no — AlreadyRunningError raised)
  :print "[lock] Another run already holds\nthe lock at the lock path. Refusing to start.";
  :sys.exit(1);
  stop
endif

:sys.exit(code);
stop
@enduml


' =============================================================================
' 3. ARTICLE FSM — process.py (per-article lifecycle, the heart of the run)
' =============================================================================
@startuml article_fsm
title Article FSM — process.py::article() (actual implementation)

[*] --> DISCOVERED : Article fetched by zendesk.fetch_all_articles()

DISCOVERED --> HASHED : md = content.html_to_markdown(art.body)\nhash = content.content_hash(md)\n(sha256 of the CLEANED markdown)

state HASHED_choice <<choice>>
HASHED --> HASHED_choice

HASHED_choice --> SKIPPED : state.get_status(id) == CONFIRMED\nAND state.get_hash(id) == hash\n(verdict = "skip")
HASHED_choice --> CLEANUP : state.get_status(id) is None (verdict="added")\nOR status == FAILED\n  (verdict="updated" if a hash was\n   previously recorded, else "added")\nOR status == CONFIRMED and hash differs\n  (verdict="updated")

SKIPPED --> [*] : Outcome.skipped(art.id) — no API calls

CLEANUP : old_ids = state.get_chunk_ids(art.id)\nfor each old file_id:\n  vector_store.delete_file(client, store_id, file_id)\n  (best-effort: exceptions per-id are caught + logged,\n   cleanup continues)
CLEANUP --> SPLIT : chunks = chunk.split_markdown(md, art.html_url)

state SPLIT_choice <<choice>>
SPLIT --> SPLIT_choice

SPLIT_choice --> CONFIRMED_EMPTY : chunks == [] (empty body)
CONFIRMED_EMPTY : state.record_confirmed(art.id, hash, [])\nOutcome.confirmed(art.id, verdict)
CONFIRMED_EMPTY --> [*]

SPLIT_choice --> UPLOAD : chunks non-empty
UPLOAD : artifacts.dump_chunks(art.id, chunks) (debug side-channel only)\nresults = uploader.upload_chunks(client, store_id, chunks,\n    article_id=art.id, content_hash=hash)\n(see "Chunk FSM" diagram)

state UPLOAD_choice <<choice>>
UPLOAD --> UPLOAD_choice

UPLOAD_choice --> CONFIRMED : all(r.status == UPLOADED for r in results)\n(all-or-nothing rule)
CONFIRMED : uploaded_ids = [r.file_id for r in results if UPLOADED]\nstate.record_confirmed(art.id, hash, uploaded_ids)\nOutcome.confirmed(art.id, verdict)
CONFIRMED --> [*]

UPLOAD_choice --> FAILED : >= 1 ChunkResult.status == FAILED
FAILED : uploaded_ids = [r.file_id for r in results if UPLOADED]\nprint each failed chunk's index + error\nstate.record_failed(art.id, uploaded_ids)\n(hash is NOT written -- lazy rollback:\n successfully uploaded chunks are kept in\n the vector store, not deleted)\nOutcome.failed(art.id)
FAILED --> [*]

note bottom
  Any exception raised anywhere in this function propagates
  to main.py's per-article try/except, which converts it to
  Outcome.failed(art.id) without calling state.record_failed
  itself (state is left however it was before this attempt).
end note
@enduml


' =============================================================================
' 4. CHUNK FSM — uploader.py::upload_chunks() (per-chunk lifecycle)
' =============================================================================
@startuml chunk_fsm
title Chunk FSM — uploader.py::upload_chunks() (per-chunk lifecycle within one article's batch)

[*] --> PENDING : ChunkText ready (from chunk.split_markdown)

state "Phase 1: base file per chunk" as Phase1 {
  PENDING --> UPLOADING : _create_base_file(client, article_id, chunk)\nclient.files.create(file=(filename, text.encode()),\n  purpose="assistants")
  UPLOADING --> [*] : success -> file_id recorded,\nentry queued with attributes\n{article_id, chunk_index, content_hash}\nand chunking_strategy=static/4096/0
  PENDING --> FAILED1 : files.create() raises exception
  FAILED1 : ChunkResult(chunk_index, file_id=None, FAILED, str(exc))
  FAILED1 --> [*]
}

state "Phase 2: one batch per article" as Phase2 {
  state BATCH_choice <<choice>>
  [*] --> CREATE_BATCH : entries non-empty
  CREATE_BATCH : client.vector_stores.file_batches.create(\n  vector_store_id=store_id, files=entries)
  CREATE_BATCH --> POLLING
  POLLING : _poll_batch(): while batch.status == "in_progress":\n  sleep(BATCH_POLL_INTERVAL_SECONDS=2.0s)\n  re-fetch via file_batches.retrieve()\n  print progress (completed/total, in_progress, elapsed)\n(no retry/backoff, no max-wait timeout yet --\n happy path only, deliberately deferred)
  POLLING --> BATCH_choice
  BATCH_choice --> ALL_UPLOADED : batch.status=="completed"\nAND counts.failed==0\nAND counts.completed==counts.total
  ALL_UPLOADED : every queued entry -> ChunkResult(..., UPLOADED)
  ALL_UPLOADED --> [*]
  BATCH_choice --> RESOLVE : otherwise (partial completion / failures)
  RESOLVE : _batch_file_status(): list_files() for the batch,\nread each file's real status + last_error.message
  state RESOLVE_choice <<choice>>
  RESOLVE --> RESOLVE_choice
  RESOLVE_choice --> UPLOADED_r : per-file status == "completed"
  UPLOADED_r : ChunkResult(idx, file_id, UPLOADED)
  UPLOADED_r --> [*]
  RESOLVE_choice --> FAILED_r : per-file status != "completed"\n(or file missing from batch response)
  FAILED_r : ChunkResult(idx, file_id, FAILED, error or status)
  FAILED_r --> [*]
  CREATE_BATCH --> BATCH_EXC : create_batch / poll / list_files\nraises an exception
  BATCH_EXC : every entry still pending in this batch\n-> ChunkResult(idx, file_id, FAILED, str(exc))
  BATCH_EXC --> [*]
}

UPLOADING --> CREATE_BATCH : (joins Phase 2 as part of "entries")
FAILED1 --> [*] : (excluded from the batch entirely --\n stays FAILED from Phase 1)

note bottom
  Final return value of upload_chunks() is the list of
  ChunkResult, one per original chunk, in the original
  chunk order -- combining whatever Phase 1 already
  marked FAILED with whatever Phase 2 resolved for the
  rest. This is what process.py's Article FSM inspects
  for the all-or-nothing CONFIRMED/FAILED decision.
end note
@enduml


' =============================================================================
' 5. EVAL RUNNER FLOW — evals/run_eval.py (independent flow, NOT part of the
'    daily sync pipeline; queries the already-deployed Assistant to check
'    response format against the verbatim system prompt's rules)
' =============================================================================
@startuml eval_runner_flow
title Eval Runner Flow — evals/run_eval.py (independent flow)

start
:main() invoked;
:reconfigure sys.stdout to utf-8, errors="replace"\n(guards against Windows cp1252 crashing on\nsmart quotes / em-dashes in assistant answers);
:settings = load_settings(); client = settings.client();

if (env var OPTIBOT_ASSISTANT_ID is set?) then (no)
  :print "ERROR: set OPTIBOT_ASSISTANT_ID to the\ndeployed Assistant's id.";
  :return 2;
  stop
else (yes)
  :valid_ids = zendesk.fetch_all_article_ids();
  note right
    Full catalog fetch, ignoring ENV's dev cap and
    without artifact dumping -- used as the oracle to
    tell a real cited article URL from a hallucinated
    one (a real citation may point outside the smaller
    uploaded subset in development mode).
  end note
  :total = 0; passed = 0;

  repeat :for (i, probe) in enumerate(QUESTIONS, start=1);
    :answer = assistant.ask(client, assistant_id, probe.question);
    note right
      client.beta.threads.create_and_run_poll(
        assistant_id=..., thread={"messages": [...]})
      -> list the newest thread message (limit=1)
      -> join all "text" content blocks
      Read-only: never creates/modifies the Assistant
      itself (its config is managed by hand, per
      state-design.md §11).
    end note
    :results = checks.run_checks(answer, valid_ids,\n  in_scope=probe.in_scope);
    note right
      check_bullet_limit  : <=5 bullets, else must
                             contain an OptiSigns doc link
      check_citation       : in-scope  -> 1..3 real
                             "Article URL:" lines required
                             out-of-scope -> exactly 0 required
      check_urls_real       : every cited OptiSigns article
                             URL must resolve to a real
                             fetched article id
    end note
    :print scope tag, question, truncated answer snippet;
    :print PASS/FAIL + detail for each check result;
    :total += len(results);
    :passed += count(results where passed);
  repeat while (more probes remaining?) is (yes) not (no)

  :print "[eval] passed/total checks passed\nacross len(QUESTIONS) question(s)";
  :return 0 if passed==total else 1;
endif
stop
@enduml
